# ─────────────────────────────────────────────────────────────────────────────
# AI Utility Toolkit — Environment Variables
# Copy this file to .env and fill in only the keys you need.
#   cp .env.example .env
# Never commit your .env file — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLMs ─────────────────────────────────────────────────────────────────────
# OpenAI — GPT-4o, GPT-4-turbo, DALL·E, Whisper API
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — Claude Sonnet, Claude Opus
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Groq — LLaMA 3.3, Mixtral (ultra-fast inference)
# https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — Gemini 1.5 Pro / Flash
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Ollama — local models (no key needed, just start the server)
# Start with: ollama serve
OLLAMA_BASE_URL=http://localhost:11434

# ── AI Image Generation ───────────────────────────────────────────────────────
# Stability AI — Stable Diffusion Core / SD3 / Ultra
# https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# Replicate — FLUX.1 Schnell / Dev / Pro
# https://replicate.com/account/api-tokens
REPLICATE_API_KEY=

# ── AI Video Generation ───────────────────────────────────────────────────────
# RunwayML — Gen-3 Alpha Turbo
# https://app.runwayml.com/settings
RUNWAY_API_KEY=

# Kling AI — Kling v1
# https://app.klingai.com/global/dev/api-keys
KLING_API_KEY=
KLING_API_SECRET=

# ── Text-to-Speech ────────────────────────────────────────────────────────────
# ElevenLabs — ultra-realistic voice synthesis
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Edge TTS — Microsoft Edge TTS (FREE, no key required)

# ── Transcription ─────────────────────────────────────────────────────────────
# AssemblyAI — speaker diarization, auto-chapters, sentiment
# https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=

# Deepgram — Nova-2 model, smart formatting
# https://console.deepgram.com/project/api-keys
DEEPGRAM_API_KEY=

# Whisper API uses OPENAI_API_KEY above.

# ── Translation ───────────────────────────────────────────────────────────────
# DeepL — highest accuracy neural machine translation
# https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Google Translate uses GOOGLE_API_KEY below.

# ── Google Cloud (shared across multiple modules) ─────────────────────────────
# Used by: Google Translate, Google Maps, Google TTS, Google Vision OCR
# https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=
# Service Account JSON path (for Vision, TTS, Translate advanced):
GOOGLE_APPLICATION_CREDENTIALS=

# ── URL Shorteners ────────────────────────────────────────────────────────────
# Bitly
# https://app.bitly.com/settings/api
BITLY_API_KEY=

# TinyURL (free tier needs no key; key enables custom aliases)
# https://tinyurl.com/app/dev
TINYURL_API_KEY=

# Rebrandly — branded short links
# https://app.rebrandly.com/account/api-keys
REBRANDLY_API_KEY=

# ── QR Code ───────────────────────────────────────────────────────────────────
# qrcode + segno — both FREE, no API keys required.
